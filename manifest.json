{
  "manifest_version": 3,
  "name": "Redirect Delay",
  "version": "1.0.0",
  "description": "Configurable delay after HTTP redirects, with optional response header float.",
  "permissions": ["debugger", "storage", "tabs", "webRequest", "scripting"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "service_worker.js",
    "type": "module"
  },
  "action": {
    "default_title": "Redirect Delay",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content_script_window_open.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["content_script.js"],
      "run_at": "document_idle"
    }
  ]
}
